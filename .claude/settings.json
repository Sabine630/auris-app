{
  "permissions": {
    "allow": [
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git push origin dev)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/guard-main-push.sh\"",
            "timeout": 10,
            "statusMessage": "檢查是否推送 main…"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/check-version-bump.sh\"",
            "timeout": 15,
            "statusMessage": "檢查版更 checklist…"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/check-secret-leak.sh\"",
            "timeout": 15,
            "statusMessage": "掃描金鑰外洩…"
          }
        ]
      }
    ]
  }
}
